    # Jangan di commit ke github cukup ambil nilainya !!
    # kalau mau mudah pake cp .env.example .env

# <> APP <>
APP_NAME=Nutrify AI - API
APP_VERSION=1.0
APP_DESCRIPTION=Indonesian Food Recognition and Recommendation For Disease

# <> MODEL <>
MODEL_PATH=nutrify_model.keras
CLASS_NAMES_PATH=class_names.json
DATASETS=indonesian_food_clean.csv

# <> CNN <>
IMG_SIZE=224

REJECT_THRESHOLD=0.61
WARN_THRESHOLD=0.62

TEMPERATURE_SCALE=5.0

# <> CORS <>
CORS=*

# <> SERVER <>
HOST=0.0.0.0
PORT=8173

# <> LOGGING <>
LOG_LEVEL=INFO

